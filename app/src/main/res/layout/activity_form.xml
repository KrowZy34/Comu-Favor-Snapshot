<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/formMain"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/dark_background"
    android:fillViewport="true"
    tools:context=".FormActivity">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="24dp"
        android:paddingEnd="24dp"
        android:paddingTop="48dp"
        android:paddingBottom="32dp">

        <!-- App name -->
        <TextView
            android:id="@+id/tvFormAppTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/form_app_title"
            android:textColor="@color/green_accent"
            android:textSize="24sp"
            android:textStyle="bold|italic"
            android:fontFamily="sans-serif" />

        <!-- Form title -->
        <TextView
            android:id="@+id/tvFormTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/form_title"
            android:textColor="@color/white"
            android:textSize="24sp"
            android:textStyle="bold"
            android:fontFamily="sans-serif"
            android:layout_marginTop="24dp" />

        <!-- Nombres -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/label_nombres"
            android:textColor="@color/green_accent"
            android:textSize="14sp"
            android:layout_marginTop="28dp" />

        <EditText
            android:id="@+id/etNombres"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:background="@drawable/input_field_bg"
            android:textColor="@color/white"
            android:textSize="16sp"
            android:inputType="textPersonName"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:autofillHints="name"
            android:layout_marginTop="6dp" />

        <!-- Apellidos -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/label_apellidos"
            android:textColor="@color/green_accent"
            android:textSize="14sp"
            android:layout_marginTop="16dp" />

        <EditText
            android:id="@+id/etApellidos"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:background="@drawable/input_field_bg"
            android:textColor="@color/white"
            android:textSize="16sp"
            android:inputType="textPersonName"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:autofillHints="name"
            android:layout_marginTop="6dp" />

        <!-- Edad -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/label_edad"
            android:textColor="@color/green_accent"
            android:textSize="14sp"
            android:layout_marginTop="16dp" />

        <EditText
            android:id="@+id/etEdad"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:background="@drawable/input_field_bg"
            android:textColor="@color/white"
            android:textSize="16sp"
            android:inputType="number"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:layout_marginTop="6dp" />

        <!-- Celular -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/label_celular"
            android:textColor="@color/green_accent"
            android:textSize="14sp"
            android:layout_marginTop="16dp" />

        <EditText
            android:id="@+id/etCelular"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:background="@drawable/input_field_bg"
            android:textColor="@color/white"
            android:textSize="16sp"
            android:inputType="phone"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:autofillHints="phone"
            android:layout_marginTop="6dp" />

        <!-- Nacionalidad (Spinner/Dropdown) -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/label_nacionalidad"
            android:textColor="@color/green_accent"
            android:textSize="14sp"
            android:layout_marginTop="16dp" />

        <Spinner
            android:id="@+id/spinnerNacionalidad"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:background="@drawable/spinner_bg"
            android:layout_marginTop="6dp" />

        <!-- Ciudad (Spinner/Dropdown) -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/label_ciudad"
            android:textColor="@color/green_accent"
            android:textSize="14sp"
            android:layout_marginTop="16dp" />

        <Spinner
            android:id="@+id/spinnerCiudad"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:background="@drawable/spinner_bg"
            android:layout_marginTop="6dp" />

        <!-- Distrito (Spinner/Dropdown) -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/label_distrito"
            android:textColor="@color/green_accent"
            android:textSize="14sp"
            android:layout_marginTop="16dp" />

        <Spinner
            android:id="@+id/spinnerDistrito"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:background="@drawable/spinner_bg"
            android:layout_marginTop="6dp" />

        <!-- Accept terms checkbox -->
        <CheckBox
            android:id="@+id/cbTerms"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/accept_terms"
            android:textColor="#80FFFFFF"
            android:textSize="12sp"
            android:buttonTint="@color/green_accent"
            android:layout_marginTop="24dp" />

        <!-- Siguiente button -->
        <Button
            android:id="@+id/btnSiguiente"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:text="@string/btn_siguiente"
            android:textColor="@color/green_accent"
            android:textSize="18sp"
            android:textAllCaps="false"
            android:background="@drawable/btn_login_border"
            android:stateListAnimator="@null"
            android:layout_marginTop="24dp"
            android:layout_marginStart="24dp"
            android:layout_marginEnd="24dp" />

        <!-- Already have account -->
        <TextView
            android:id="@+id/tvAlreadyHaveAccount"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:textSize="14sp"
            android:textColor="@color/white"
            android:layout_marginTop="16dp" />

        <!-- Terms of use title -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/terms_title"
            android:textColor="#80FFFFFF"
            android:textSize="10sp"
            android:layout_marginTop="16dp" />

        <!-- Terms of use body -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/terms_body"
            android:textColor="#80FFFFFF"
            android:textSize="10sp"
            android:layout_marginTop="4dp" />

    </LinearLayout>
</ScrollView>
