<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_job_card"
    android:layout_marginBottom="12dp"
    android:layout_marginEnd="16dp"
    android:layout_marginStart="8dp"
    android:padding="16dp">

    <TextView
        android:id="@+id/tvJobTitle"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Limpieza de local 54 m²"
        android:textColor="@color/white"
        android:textSize="18sp"
        android:textStyle="bold"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/tvJobLocation"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:text="Lima, Independencia"
        android:textColor="@color/white"
        android:textSize="14sp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tvJobTitle" />

    <TextView
        android:id="@+id/tvJobPrice"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="S/negociable"
        android:textColor="@color/price_text"
        android:textSize="16sp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toStartOf="@id/tvJobDate"
        app:layout_constraintTop_toBottomOf="@id/tvJobLocation" />

    <TextView
        android:id="@+id/tvJobDate"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="10/10/25"
        android:textColor="@color/white"
        android:textSize="14sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toBottomOf="@id/tvJobPrice"
        app:layout_constraintTop_toTopOf="@id/tvJobPrice" />

</androidx.constraintlayout.widget.ConstraintLayout>
