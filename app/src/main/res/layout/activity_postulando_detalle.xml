<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/detalleEmpleoMain"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/black"
    tools:context=".PostulandoDetalleActivity">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:fillViewport="true"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@id/bottomNavDivider">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingTop="32dp"
            android:paddingBottom="16dp"
            android:paddingStart="24dp"
            android:paddingEnd="24dp">

            <!-- Title and 3-dots -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="4dp">

                <TextView
                    android:id="@+id/tvJobTitle"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Limpieza de local 54 m²"
                    android:textColor="@color/white"
                    android:textSize="22sp"
                    android:textStyle="bold" />

                <ImageView
                    android:id="@+id/ivMoreOptions"
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:src="@drawable/ic_more_vert"
                    android:padding="2dp"
                    android:contentDescription="Options"
                    android:clickable="true"
                    android:focusable="true"/>
            </LinearLayout>

            <TextView
                android:id="@+id/tvJobLocation"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Lima, Independencia"
                android:textColor="@color/white"
                android:textSize="14sp" />

            <TextView
                android:id="@+id/tvJobDate"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="10/10/25"
                android:textColor="@color/white"
                android:textSize="14sp"
                android:layout_marginBottom="24dp" />

            <!-- Empleador -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/empleo_empleador"
                android:textColor="@color/green_accent"
                android:textSize="18sp"
                android:layout_marginBottom="8dp" />

            <TextView
                android:id="@+id/tvEmpleador"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="• Sandro Chavez"
                android:textColor="@color/white"
                android:textSize="16sp"
                android:layout_marginStart="8dp"
                android:layout_marginBottom="20dp" />

            <!-- Pago -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/empleo_pago"
                android:textColor="@color/green_accent"
                android:textSize="18sp"
                android:layout_marginBottom="8dp" />

            <TextView
                android:id="@+id/tvPago"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="• S/negociable"
                android:textColor="@color/white"
                android:textSize="16sp"
                android:layout_marginStart="8dp"
                android:layout_marginBottom="20dp" />

            <!-- Información -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/empleo_informacion"
                android:textColor="@color/green_accent"
                android:textSize="20sp"
                android:layout_marginBottom="12dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_card_rec"
                android:padding="16dp"
                android:layout_marginBottom="32dp">

                <TextView
                    android:id="@+id/tvInformacion"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="@color/white"
                    android:textSize="16sp"
                    android:lineSpacingExtra="4dp"
                    android:text="Se requiere personal de limpieza para local comercial. Sus tareas principales serán el barrido, trapeado de pisos, limpieza de lunas y desinfección de los servicios higiénicos. Se proporcionarán todos los implementos de limpieza necesarios. Horario flexible, coordinar disponibilidad. mas" />
            </LinearLayout>
        </LinearLayout>
    </ScrollView>

    <!-- Popup Menu layout for styling, we'll use a PopupWindow to match the exact mockup perfectly instead of standard PopupMenu which might be hard to style identically without complex theme hacking -->
    
    <!-- Bottom Navigation -->
    <View
        android:id="@+id/bottomNavDivider"
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/card_border"
        app:layout_constraintBottom_toTopOf="@id/bottomNav" />

    <LinearLayout
        android:id="@+id/bottomNav"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="@color/black"
        android:paddingTop="8dp"
        android:paddingBottom="8dp"
        android:weightSum="5"
        app:layout_constraintBottom_toBottomOf="parent">

        <!-- Rec & Post (Active in this view) -->
        <LinearLayout
            android:id="@+id/navRecPost"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">

            <!-- Active icon in green -->
            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_briefcase"
                app:tint="@color/green_accent"
                android:layout_marginBottom="4dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/nav_rec_post"
                android:textColor="@color/green_accent"
                android:textSize="10sp"
                android:textStyle="bold"
                android:textAlignment="center" />
        </LinearLayout>

        <!-- Mensajes -->
        <LinearLayout
            android:id="@+id/navMensajes"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_chat"
                android:layout_marginBottom="4dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/nav_mensajes"
                android:textColor="@color/white"
                android:textSize="10sp"
                android:textStyle="bold"
                android:textAlignment="center" />
        </LinearLayout>

        <!-- Inicio (Inactive) -->
        <LinearLayout
            android:id="@+id/navInicio"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">

            <ImageView
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:src="@drawable/ic_home_filled"
                app:tint="@color/white"
                android:layout_marginBottom="2dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/nav_inicio"
                android:textColor="@color/white"
                android:textSize="10sp"
                android:textStyle="bold"
                android:textAlignment="center" />
        </LinearLayout>

        <!-- Guardados -->
        <LinearLayout
            android:id="@+id/navGuardados"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_bookmark"
                android:layout_marginBottom="4dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/nav_guardados"
                android:textColor="@color/white"
                android:textSize="10sp"
                android:textStyle="bold"
                android:textAlignment="center" />
        </LinearLayout>

        <!-- Perfil -->
        <LinearLayout
            android:id="@+id/navPerfil"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_profile_outline"
                android:layout_marginBottom="4dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/nav_perfil"
                android:textColor="@color/white"
                android:textSize="10sp"
                android:textStyle="bold"
                android:textAlignment="center" />
        </LinearLayout>

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
