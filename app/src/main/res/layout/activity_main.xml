<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".MainActivity">

    <!-- Background image -->
    <ImageView
        android:id="@+id/bgImage"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scaleType="centerCrop"
        android:src="@drawable/bg_login"
        android:contentDescription="@string/app_name" />

    <!-- Dark overlay -->
    <View
        android:id="@+id/darkOverlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/dark_overlay" />

    <!-- Scrollable content -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        android:scrollbars="none">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="32dp"
            android:paddingEnd="32dp"
            android:paddingTop="48dp"
            android:paddingBottom="32dp">

            <!-- App logo + title row -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <ImageView
                    android:id="@+id/ivLogo"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:src="@drawable/krowdar_logo"
                    android:contentDescription="@string/app_name"
                    android:layout_marginEnd="8dp" />

                <TextView
                    android:id="@+id/tvTitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/login_title"
                    android:textColor="@color/green_accent"
                    android:textSize="30sp"
                    android:textStyle="bold|italic"
                    android:fontFamily="sans-serif" />

            </LinearLayout>

            <!-- Spacer that compresses when keyboard opens -->
            <View
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1" />

            <!-- Tagline -->
            <TextView
                android:id="@+id/tvTagline"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/login_tagline"
                android:textColor="@color/white"
                android:textSize="26sp"
                android:textStyle="bold"
                android:lineSpacingExtra="4dp"
                android:fontFamily="sans-serif"
                android:layout_marginBottom="28dp" />

            <!-- Email label -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/label_email"
                android:textColor="@color/green_accent"
                android:textSize="13sp" />

            <!-- Email input -->
            <EditText
                android:id="@+id/etEmail"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:hint="@string/hint_email"
                android:textColorHint="@color/input_hint"
                android:textColor="@color/green_accent"
                android:textSize="16sp"
                android:inputType="textEmailAddress"
                android:background="@android:color/transparent"
                android:paddingStart="0dp"
                android:paddingEnd="0dp"
                android:autofillHints="emailAddress"
                android:layout_marginTop="2dp" />

            <!-- Email underline -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@color/green_accent" />

            <!-- Password label -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/label_password"
                android:textColor="@color/green_accent"
                android:textSize="13sp"
                android:layout_marginTop="16dp" />

            <!-- Password input -->
            <EditText
                android:id="@+id/etPassword"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:hint="@string/hint_password"
                android:textColorHint="@color/input_hint"
                android:textColor="@color/green_accent"
                android:textSize="16sp"
                android:inputType="textPassword"
                android:background="@android:color/transparent"
                android:paddingStart="0dp"
                android:paddingEnd="0dp"
                android:autofillHints="password"
                android:layout_marginTop="2dp" />

            <!-- Password underline -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@color/green_accent" />

            <!-- Remember checkbox -->
            <CheckBox
                android:id="@+id/cbRemember"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/remember_device"
                android:textColor="@color/white"
                android:textSize="11sp"
                android:buttonTint="@color/green_accent"
                android:layout_marginTop="10dp" />

            <!-- Login button -->
            <Button
                android:id="@+id/btnLogin"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:text="@string/btn_login"
                android:textColor="@color/green_accent"
                android:textSize="18sp"
                android:textAllCaps="false"
                android:background="@drawable/btn_login_border"
                android:stateListAnimator="@null"
                android:layout_marginTop="24dp"
                android:layout_marginStart="20dp"
                android:layout_marginEnd="20dp" />

            <!-- "o Crear Cuenta" -->
            <TextView
                android:id="@+id/tvCreateAccount"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:textSize="14sp"
                android:textColor="@color/white"
                android:layout_marginTop="14dp"
                android:layout_marginBottom="8dp" />

        </LinearLayout>
    </ScrollView>

</FrameLayout>