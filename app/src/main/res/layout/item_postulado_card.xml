<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/cardRoot"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_postulado_card_grey"
    android:layout_marginBottom="12dp"
    android:padding="16dp">

    <!-- Title -->
    <TextView
        android:id="@+id/tvJobTitle"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Limpieza de local 54 m²"
        android:textColor="#111111"
        android:textSize="18sp"
        android:textStyle="bold"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toStartOf="@id/ivBookmark"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- Bookmark icon -->
    <ImageView
        android:id="@+id/ivBookmark"
        android:layout_width="22dp"
        android:layout_height="22dp"
        android:src="@drawable/ic_bookmark_outline"
        app:tint="#999999"
        android:contentDescription="Guardar"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- Location -->
    <TextView
        android:id="@+id/tvJobLocation"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:text="Lima, Independencia"
        android:textColor="#666666"
        android:textSize="14sp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tvJobTitle" />

    <!-- Price -->
    <TextView
        android:id="@+id/tvJobPrice"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:text="S/negociable"
        android:textColor="@color/price_red"
        android:textSize="16sp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tvJobLocation" />

    <!-- Date -->
    <TextView
        android:id="@+id/tvJobDate"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:text="10/10/25"
        android:textColor="#999999"
        android:textSize="13sp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tvJobPrice" />

    <!-- Rating -->
    <TextView
        android:id="@+id/tvJobRating"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="4.5"
        android:textColor="#333333"
        android:textSize="16sp"
        android:textStyle="bold"
        android:layout_marginTop="8dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tvJobDate" />

    <!-- Star icon -->
    <ImageView
        android:id="@+id/ivJobStar"
        android:layout_width="18dp"
        android:layout_height="18dp"
        android:src="@drawable/ic_star_filled"
        android:contentDescription="Rating"
        android:layout_marginStart="4dp"
        app:layout_constraintStart_toEndOf="@id/tvJobRating"
        app:layout_constraintTop_toTopOf="@id/tvJobRating"
        app:layout_constraintBottom_toBottomOf="@id/tvJobRating" />

    <!-- Status icon (checkmark for confirmado/finalizado) -->
    <ImageView
        android:id="@+id/ivStatusIcon"
        android:layout_width="24dp"
        android:layout_height="24dp"
        android:src="@drawable/ic_check_circle"
        android:contentDescription="Status"
        android:visibility="gone"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="@id/tvJobRating"
        app:layout_constraintBottom_toBottomOf="@id/tvJobRating" />

    <!-- Loading spinner (for en_proceso / propuesta_enviada) -->
    <ProgressBar
        android:id="@+id/pbStatusSpinner"
        android:layout_width="22dp"
        android:layout_height="22dp"
        android:indeterminate="true"
        android:visibility="gone"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="@id/tvJobRating"
        app:layout_constraintBottom_toBottomOf="@id/tvJobRating" />

    <!-- Status text -->
    <TextView
        android:id="@+id/tvStatusText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Propuesta enviada"
        android:textColor="#555555"
        android:textSize="14sp"
        android:visibility="gone"
        android:layout_marginEnd="8dp"
        app:layout_constraintEnd_toStartOf="@id/ivStatusIcon"
        app:layout_constraintTop_toTopOf="@id/tvJobRating"
        app:layout_constraintBottom_toBottomOf="@id/tvJobRating" />

</androidx.constraintlayout.widget.ConstraintLayout>
