<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/createAccountMain"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/dark_background"
    android:fillViewport="true"
    android:scrollbars="none"
    tools:context=".CreateAccountActivity">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="32dp"
        android:paddingEnd="32dp"
        android:paddingTop="48dp"
        android:paddingBottom="32dp">

        <!-- App name -->
        <TextView
            android:id="@+id/tvCreateAppTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/form_app_title"
            android:textColor="@color/green_accent"
            android:textSize="24sp"
            android:textStyle="bold|italic"
            android:fontFamily="sans-serif" />

        <!-- Crear cuenta title -->
        <TextView
            android:id="@+id/tvCreateTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/crear_cuenta_title"
            android:textColor="@color/green_accent"
            android:textSize="26sp"
            android:textStyle="bold"
            android:fontFamily="sans-serif"
            android:gravity="center"
            android:layout_marginTop="32dp" />

        <!-- Email label -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/label_email"
            android:textColor="@color/green_accent"
            android:textSize="13sp"
            android:layout_marginTop="36dp" />

        <!-- Email input -->
        <EditText
            android:id="@+id/etCreateEmail"
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:hint="@string/hint_email"
            android:textColorHint="@color/input_hint"
            android:textColor="@color/green_accent"
            android:textSize="16sp"
            android:inputType="textEmailAddress"
            android:background="@android:color/transparent"
            android:paddingStart="0dp"
            android:paddingEnd="0dp"
            android:autofillHints="emailAddress"
            android:layout_marginTop="2dp" />

        <!-- Email underline -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/green_accent" />

        <!-- Password label -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/label_password"
            android:textColor="@color/green_accent"
            android:textSize="13sp"
            android:layout_marginTop="16dp" />

        <!-- Password input -->
        <EditText
            android:id="@+id/etCreatePassword"
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:hint="@string/hint_password"
            android:textColorHint="@color/input_hint"
            android:textColor="@color/green_accent"
            android:textSize="16sp"
            android:inputType="textPassword"
            android:background="@android:color/transparent"
            android:paddingStart="0dp"
            android:paddingEnd="0dp"
            android:autofillHints="password"
            android:layout_marginTop="2dp" />

        <!-- Password underline -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/green_accent" />

        <!-- Remember checkbox -->
        <CheckBox
            android:id="@+id/cbCreateRemember"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/remember_device"
            android:textColor="#80FFFFFF"
            android:textSize="11sp"
            android:buttonTint="@color/green_accent"
            android:layout_marginTop="10dp" />

        <!-- Acceder button -->
        <Button
            android:id="@+id/btnCreateAcceder"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:text="@string/btn_login"
            android:textColor="@color/green_accent"
            android:textSize="18sp"
            android:textAllCaps="false"
            android:background="@drawable/btn_login_border"
            android:stateListAnimator="@null"
            android:layout_marginTop="24dp"
            android:layout_marginStart="20dp"
            android:layout_marginEnd="20dp" />

        <!-- Already have account -->
        <TextView
            android:id="@+id/tvCreateAlreadyAccount"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:textSize="14sp"
            android:textColor="@color/white"
            android:layout_marginTop="14dp" />

        <!-- App description -->
        <TextView
            android:id="@+id/tvAppDescription"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/app_description"
            android:textColor="#80FFFFFF"
            android:textSize="10sp"
            android:lineSpacingExtra="2dp"
            android:layout_marginTop="28dp" />

    </LinearLayout>
</ScrollView>
