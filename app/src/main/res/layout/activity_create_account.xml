<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/createAccountMain"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".CreateAccountActivity">

    <!-- Background image (same as login) -->
    <ImageView
        android:id="@+id/bgImage"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scaleType="centerCrop"
        android:src="@drawable/bg_login"
        android:contentDescription="@string/app_name"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Gradient overlay -->
    <ImageView
        android:id="@+id/gradientOverlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scaleType="centerCrop"
        android:src="@drawable/bg_login_gradient_img"
        android:contentDescription="Gradient"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- App logo at top left (matches login screen) -->
    <ImageView
        android:id="@+id/ivLogo"
        android:layout_width="64dp"
        android:layout_height="64dp"
        android:layout_marginStart="24dp"
        android:layout_marginTop="32dp"
        android:src="@drawable/krowdar_logo"
        android:contentDescription="@string/app_name"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- Scrollable content -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_marginTop="20dp"
        android:backgroundTint="@color/transparent"
        android:background="@android:color/transparent"
        android:fillViewport="true"
        android:scrollbars="none"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.0"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_bias="1.0">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="40dp"
            android:paddingEnd="40dp"
            android:paddingTop="32dp"
            android:paddingBottom="32dp">

            <!-- Spacer -->
            <View
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1" />

            <!-- Regístrate title -->
            <TextView
                android:id="@+id/tvCreateTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="40dp"
                android:fontFamily="sans-serif"
                android:lineSpacingExtra="2dp"
                android:text="@string/crear_cuenta_title"
                android:textColor="@color/purple_login"
                android:textSize="26sp"
                android:textStyle="normal" />

            <!-- Nombres label -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Nombres"
                android:textColor="@color/purple_login"
                android:textSize="14sp" />

            <!-- Nombres input -->
            <EditText
                android:id="@+id/etCreateFirstName"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:autofillHints="name"
                android:background="@android:color/transparent"
                android:hint="Ej. Juan"
                android:inputType="textPersonName"
                android:paddingStart="0dp"
                android:paddingEnd="0dp"
                android:textColor="@color/purple_login"
                android:textColorHint="@color/purple_login_hint"
                android:textSize="20sp" />

            <!-- Nombres underline -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@color/purple_login" />

            <!-- Apellidos label -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:text="Apellidos"
                android:textColor="@color/purple_login"
                android:textSize="14sp" />

            <!-- Apellidos input -->
            <EditText
                android:id="@+id/etCreateLastName"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:autofillHints="name"
                android:background="@android:color/transparent"
                android:hint="Ej. Perez"
                android:inputType="textPersonName"
                android:paddingStart="0dp"
                android:paddingEnd="0dp"
                android:textColor="@color/purple_login"
                android:textColorHint="@color/purple_login_hint"
                android:textSize="20sp" />

            <!-- Apellidos underline -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@color/purple_login" />

            <!-- Phone label -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:text="@string/label_celular"
                android:textColor="@color/purple_login"
                android:textSize="14sp" />

            <!-- Phone input -->
            <EditText
                android:id="@+id/etPhone"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:autofillHints="phone"
                android:background="@android:color/transparent"
                android:hint="@string/hint_celular"
                android:inputType="phone"
                android:maxLength="9"
                android:paddingStart="0dp"
                android:paddingEnd="0dp"
                android:textColor="@color/purple_login"
                android:textColorHint="@color/purple_login_hint"
                android:textSize="20sp" />

            <!-- Phone underline -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@color/purple_login" />

            <!-- Email label -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:text="@string/label_email"
                android:textColor="@color/purple_login"
                android:textSize="14sp" />

            <!-- Email input -->
            <EditText
                android:id="@+id/etCreateEmail"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:autofillHints="emailAddress"
                android:background="@android:color/transparent"
                android:hint="@string/hint_email"
                android:inputType="textEmailAddress"
                android:paddingStart="0dp"
                android:paddingEnd="0dp"
                android:textColor="@color/purple_login"
                android:textColorHint="@color/purple_login_hint"
                android:textSize="20sp" />

            <!-- Email underline -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@color/purple_login" />

            <!-- Password label -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:text="@string/label_password"
                android:textColor="@color/purple_login"
                android:textSize="14sp" />

            <!-- Password input with toggle -->
            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="48dp">

                <EditText
                    android:id="@+id/etCreatePassword"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:autofillHints="password"
                    android:background="@android:color/transparent"
                    android:hint="@string/hint_password"
                    android:inputType="textPassword"
                    android:paddingStart="0dp"
                    android:paddingEnd="40dp"
                    android:textColor="@color/purple_login"
                    android:textColorHint="@color/purple_login_hint"
                    android:textSize="20sp" />

                <ImageView
                    android:id="@+id/ivTogglePassword"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:layout_gravity="center_vertical|end"
                    android:src="@drawable/ic_ocultar"
                    android:contentDescription="Toggle password visibility"
                    android:clickable="true"
                    android:focusable="true" />
            </FrameLayout>

            <!-- Password underline -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@color/purple_login" />

            <!-- Remember checkbox (replaces terms) -->
            <CheckBox
                android:id="@+id/cbRemember"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:buttonTint="@color/purple_login"
                android:text="@string/accept_terms"
                android:textColor="@color/purple_login_hint"
                android:textSize="12sp" />

            <View
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1" />

            <!-- Acceder button -->
            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/btnCreateAcceder"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:layout_marginStart="24dp"
                android:layout_marginTop="32dp"
                android:layout_marginEnd="24dp"
                android:background="@drawable/btn_login_new_border"
                app:backgroundTint="@null"
                android:backgroundTint="@null"
                android:stateListAnimator="@null"
                android:text="@string/create_account"
                android:textAllCaps="false"
                android:textColor="@color/purple_login"
                android:textSize="22sp" />

            <!-- "o Crear Cuenta" link back to Login -->
            <TextView
                android:id="@+id/tvCreateAlreadyAccount"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:layout_marginBottom="16dp"
                android:gravity="center"
                android:text="o iniciar sesión"
                android:textColor="@color/purple_login"
                android:textSize="14sp" />

        </LinearLayout>
    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>
