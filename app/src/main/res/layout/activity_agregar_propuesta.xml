<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/agregarPropuestaMain"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/black"
    tools:context=".AgregarPropuestaActivity">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:fillViewport="true"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@id/bottomNavDivider">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingTop="32dp"
            android:paddingBottom="16dp"
            android:paddingStart="24dp"
            android:paddingEnd="24dp">

            <!-- App Title Component Header could replace this but the mockup just shows the title text -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/add_job_title"
                android:textColor="@color/green_accent"
                android:textSize="26sp"
                android:layout_marginBottom="32dp" />

            <!-- Title Input -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="24dp"
                android:gravity="center_vertical">
                
                <TextView
                    android:layout_width="100dp"
                    android:layout_height="wrap_content"
                    android:text="@string/add_job_label_title"
                    android:textColor="@color/orange_red_accent"
                    android:textSize="20sp" />
                
                <EditText
                    android:id="@+id/etTitle"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:background="@android:color/transparent"
                    android:hint="@string/add_job_hint_title"
                    android:textColorHint="@color/text_secondary"
                    android:textColor="@color/white"
                    android:textSize="18sp"
                    android:inputType="text" />
            </LinearLayout>

            <!-- Location Input -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="24dp"
                android:gravity="center_vertical">
                
                <TextView
                    android:layout_width="100dp"
                    android:layout_height="wrap_content"
                    android:text="@string/add_job_label_location"
                    android:textColor="@color/orange_red_accent"
                    android:textSize="20sp" />
                
                <EditText
                    android:id="@+id/etLocation"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:background="@android:color/transparent"
                    android:hint="@string/add_job_hint_location"
                    android:textColorHint="@color/text_secondary"
                    android:textColor="@color/white"
                    android:textSize="18sp"
                    android:inputType="text" />
            </LinearLayout>

            <!-- Payment Input -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="32dp"
                android:gravity="center_vertical">
                
                <TextView
                    android:layout_width="100dp"
                    android:layout_height="wrap_content"
                    android:text="@string/add_job_label_payment"
                    android:textColor="@color/orange_red_accent"
                    android:textSize="20sp" />
                
                <EditText
                    android:id="@+id/etPayment"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:background="@android:color/transparent"
                    android:hint="@string/add_job_hint_payment"
                    android:textColorHint="@color/text_secondary"
                    android:textColor="@color/white"
                    android:textSize="18sp"
                    android:inputType="text" />
            </LinearLayout>

            <!-- Information Section -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/add_job_label_info"
                android:textColor="@color/orange_red_accent"
                android:textSize="22sp"
                android:layout_marginBottom="16dp" />

            <EditText
                android:id="@+id/etInformation"
                android:layout_width="match_parent"
                android:layout_height="180dp"
                android:background="@drawable/bg_info_input"
                android:gravity="center"
                android:hint="@string/add_job_hint_info"
                android:textColorHint="@color/text_secondary"
                android:textColor="@color/white"
                android:textSize="16sp"
                android:inputType="textMultiLine"
                android:padding="24dp"
                android:layout_marginBottom="24dp" />

            <!-- Submit Button (Added for functionality) -->
            <Button
                android:id="@+id/btnSubmitJob"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:backgroundTint="@color/green_accent"
                android:textColor="@color/black"
                android:textStyle="bold"
                android:text="@string/add_job_button"
                android:layout_marginBottom="32dp" />

        </LinearLayout>
    </ScrollView>

    <!-- Bottom Navigation -->
    <View
        android:id="@+id/bottomNavDivider"
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/card_border"
        app:layout_constraintBottom_toTopOf="@id/bottomNav" />

    <LinearLayout
        android:id="@+id/bottomNav"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="@color/black"
        android:paddingTop="8dp"
        android:paddingBottom="8dp"
        android:weightSum="5"
        app:layout_constraintBottom_toBottomOf="parent">

        <!-- Rec & Post (Active in this view) -->
        <LinearLayout
            android:id="@+id/navRecPost"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">

            <!-- Active icon in green -->
            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_briefcase"
                app:tint="@color/green_accent"
                android:layout_marginBottom="4dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/nav_rec_post"
                android:textColor="@color/green_accent"
                android:textSize="10sp"
                android:textStyle="bold"
                android:textAlignment="center" />
        </LinearLayout>

        <!-- Mensajes -->
        <LinearLayout
            android:id="@+id/navMensajes"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_chat"
                android:layout_marginBottom="4dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/nav_mensajes"
                android:textColor="@color/white"
                android:textSize="10sp"
                android:textStyle="bold"
                android:textAlignment="center" />
        </LinearLayout>

        <!-- Inicio (Inactive) -->
        <LinearLayout
            android:id="@+id/navInicio"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">

            <ImageView
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:src="@drawable/ic_home_filled"
                app:tint="@color/white"
                android:layout_marginBottom="2dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/nav_inicio"
                android:textColor="@color/white"
                android:textSize="10sp"
                android:textStyle="bold"
                android:textAlignment="center" />
        </LinearLayout>

        <!-- Guardados -->
        <LinearLayout
            android:id="@+id/navGuardados"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_bookmark"
                android:layout_marginBottom="4dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/nav_guardados"
                android:textColor="@color/white"
                android:textSize="10sp"
                android:textStyle="bold"
                android:textAlignment="center" />
        </LinearLayout>

        <!-- Perfil -->
        <LinearLayout
            android:id="@+id/navPerfil"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_profile_outline"
                android:layout_marginBottom="4dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/nav_perfil"
                android:textColor="@color/white"
                android:textSize="10sp"
                android:textStyle="bold"
                android:textAlignment="center" />
        </LinearLayout>

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
