<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/acceptedJobDetailMain"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white"
    tools:context=".AcceptedJobDetailActivity">

    <!-- Scrollable Content -->
    <ScrollView
        android:id="@+id/scrollContent"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginTop="16dp"
        android:scrollbars="none"
        android:fillViewport="true"
        app:layout_constraintBottom_toTopOf="@id/actionArea"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="24dp"
            android:paddingEnd="24dp"
            android:paddingBottom="16dp">

            <!-- Yellow Bordered Job Card -->
            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_yellow_border_card"
                android:padding="12dp"
                android:layout_marginBottom="24dp">

                <!-- Title -->
                <TextView
                    android:id="@+id/tvJobTitle"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:text="Limpieza de local 54 m²"
                    android:textColor="#111111"
                    android:textSize="18sp"
                    android:textStyle="normal"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toStartOf="@id/ivPhone"
                    app:layout_constraintTop_toTopOf="parent" />

                <!-- Location (Short) -->
                <TextView
                    android:id="@+id/tvJobLocationShort"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:text="Lima, Independencia"
                    android:textColor="#333333"
                    android:textSize="14sp"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toStartOf="@id/ivPhone"
                    app:layout_constraintTop_toBottomOf="@id/tvJobTitle" />

                <!-- Price -->
                <TextView
                    android:id="@+id/tvJobPrice"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="S/negociable"
                    android:textColor="#D32F2F"
                    android:textSize="14sp"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/tvJobLocationShort" />

                <!-- Date -->
                <TextView
                    android:id="@+id/tvJobDate"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="10/10/25"
                    android:textColor="#111111"
                    android:textSize="14sp"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/tvJobPrice" />

                <!-- Phone icon -->
                <ImageView
                    android:id="@+id/ivPhone"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:layout_marginEnd="12dp"
                    android:src="@drawable/ic_phone"
                    app:tint="#111111"
                    android:contentDescription="Llamar"
                    app:layout_constraintEnd_toStartOf="@id/ivMessage"
                    app:layout_constraintTop_toTopOf="parent" />

                <!-- Message icon -->
                <ImageView
                    android:id="@+id/ivMessage"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/ic_chat"
                    app:tint="#111111"
                    android:contentDescription="Mensaje"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />

            </androidx.constraintlayout.widget.ConstraintLayout>

            <!-- Reclutador Section -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Reclutador"
                android:textColor="#111111"
                android:textSize="20sp"
                android:textStyle="normal"
                android:layout_marginBottom="4dp" />

            <TextView
                android:id="@+id/tvRecruiterName"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Sandro Rodrigo Chavez Barrios"
                android:textColor="#333333"
                android:textSize="15sp"
                android:layout_marginBottom="16dp" />

            <!-- Ubicación Section -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Ubicación"
                android:textColor="#111111"
                android:textSize="20sp"
                android:textStyle="normal"
                android:layout_marginBottom="4dp" />

            <TextView
                android:id="@+id/tvFullAddress"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Independencia\nAv. Alfredo Mendiola 3520, Lima 15311"
                android:textColor="#333333"
                android:textSize="15sp"
                android:layout_marginBottom="16dp" />

            <!-- Description Section -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Descripción"
                android:textColor="#111111"
                android:textSize="20sp"
                android:textStyle="normal"
                android:layout_marginBottom="12dp" />

            <TextView
                android:id="@+id/tvDescription"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Se requiere servicio de limpieza para un cuarto de aproximadamente 54 metros cuadrados. El espacio contiene basura, cajas y algunos electrodomésticos, por lo que será necesario organizar, retirar residuos y realizar una limpieza general del área.\nEl lugar sigue siendo accesible, por lo que se puede trabajar sin mayores dificultades. Se busca dejar el espacio ordenado y limpio."
                android:textColor="#333333"
                android:textSize="15sp"
                android:lineSpacingExtra="2dp"
                android:justificationMode="inter_word"
                android:layout_marginBottom="24dp"
                tools:targetApi="o" />

            <!-- Photo Section (conditionally visible) -->
            <LinearLayout
                android:id="@+id/photoSection"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">

                <!-- Photo Title -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Muestra fotográfica"
                    android:textColor="#111111"
                    android:textSize="20sp"
                    android:textStyle="normal"
                    android:layout_marginBottom="16dp" />

                <!-- Image Placeholder 1 -->
                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="160dp"
                    android:background="@drawable/bg_image_placeholder"
                    android:layout_marginBottom="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center"
                        android:text="Imagenes"
                        android:textColor="#999999"
                        android:textSize="16sp" />
                </FrameLayout>

                <!-- Image Placeholder 2 -->
                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="160dp"
                    android:background="@drawable/bg_image_placeholder"
                    android:layout_marginBottom="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center"
                        android:text="Imagenes"
                        android:textColor="#999999"
                        android:textSize="16sp" />
                </FrameLayout>

            </LinearLayout>

        </LinearLayout>
    </ScrollView>

    <!-- Bottom Action Area -->
    <FrameLayout
        android:id="@+id/actionArea"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:layout_constraintBottom_toTopOf="@id/bottomNavDivider"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:background="@color/white">

        <!-- Confirmado Row (Default) -->
        <LinearLayout
            android:id="@+id/actionConfirmadoRow"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="24dp"
            android:paddingVertical="16dp">

            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/btnAccept"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:text="Acepto el trabajo"
                android:textColor="#111111"
                android:textSize="18sp"
                android:textAllCaps="false"
                android:background="@drawable/bg_btn_green_accept"
                app:backgroundTint="@null"
                android:backgroundTint="@null"
                android:stateListAnimator="@null"
                android:layout_marginBottom="12dp" />

            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/btnCancel"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:text="Cancelar"
                android:textColor="#111111"
                android:textSize="18sp"
                android:textAllCaps="false"
                android:background="@drawable/bg_btn_red_cancel"
                app:backgroundTint="@null"
                android:backgroundTint="@null"
                android:stateListAnimator="@null" />
        </LinearLayout>

        <!-- En Proceso Row -->
        <LinearLayout
            android:id="@+id/actionEnProcesoRow"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:paddingHorizontal="24dp"
            android:paddingVertical="16dp"
            android:visibility="gone">

            <TextView
                android:id="@+id/btnCancelEnProceso"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:text="Cancelar"
                android:textColor="#111111"
                android:textSize="16sp" />

            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/btnTrabajoCompleto"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1.2"
                android:background="@drawable/bg_btn_orange_rounded"
                android:text="Trabajo completo"
                android:textColor="#111111"
                android:textSize="16sp"
                android:textAllCaps="false"
                android:textStyle="normal"
                app:backgroundTint="@null"
                android:backgroundTint="@null"
                android:stateListAnimator="@null" />
        </LinearLayout>

        <!-- Finalizado Row -->
        <LinearLayout
            android:id="@+id/actionFinalizadoRow"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:paddingHorizontal="24dp"
            android:paddingVertical="16dp"
            android:visibility="gone">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center"
                android:background="@drawable/bg_btn_red_wait"
                android:paddingHorizontal="16dp"
                android:paddingVertical="12dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="espere a que el empleador confirme la\nfinalización de el trabajo"
                    android:textColor="#111111"
                    android:textSize="14sp"
                    android:gravity="center" />

                <ProgressBar
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:indeterminate="true"
                    android:indeterminateTint="#D32F2F"
                    android:layout_marginStart="8dp" />
            </LinearLayout>
        </LinearLayout>

    </FrameLayout>

    <!-- Bottom Navigation Divider -->
    <View
        android:id="@+id/bottomNavDivider"
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#E0E0E0"
        app:layout_constraintBottom_toTopOf="@id/bottomNavMain"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <!-- Bottom Navigation (Standard) -->
    <LinearLayout
        android:id="@+id/bottomNavMain"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:background="@color/white"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingTop="4dp"
        android:paddingBottom="4dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <!-- Postulado -->
        <LinearLayout
            android:id="@+id/navPostulado"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">

            <ImageView
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:src="@drawable/ic_briefcase"
                app:tint="@color/purple_login"
                android:contentDescription="Postulado" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Postulado"
                android:textColor="@color/purple_login"
                android:textSize="10sp"
                android:textStyle="bold"
                android:layout_marginTop="2dp" />
        </LinearLayout>

        <!-- Recomen -->
        <LinearLayout
            android:id="@+id/navRecomen"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_star_outline"
                app:tint="#999999"
                android:contentDescription="Recomen" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Recomen"
                android:textColor="#999999"
                android:textSize="10sp"
                android:layout_marginTop="2dp" />
        </LinearLayout>

        <!-- Inicio -->
        <LinearLayout
            android:id="@+id/navInicio"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_home_filled"
                app:tint="#999999"
                android:contentDescription="Inicio" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Inicio"
                android:textColor="#999999"
                android:textSize="10sp"
                android:layout_marginTop="2dp" />
        </LinearLayout>

        <!-- Guardados -->
        <LinearLayout
            android:id="@+id/navGuardados"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_bookmark_outline"
                app:tint="#999999"
                android:contentDescription="Guardados" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Guardados"
                android:textColor="#999999"
                android:textSize="10sp"
                android:layout_marginTop="2dp" />
        </LinearLayout>

        <!-- Perfil -->
        <LinearLayout
            android:id="@+id/navCuenta"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_nav_account"
                android:contentDescription="Cuenta" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Cuenta"
                android:textColor="#999999"
                android:textSize="10sp"
                android:layout_marginTop="2dp" />
        </LinearLayout>

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
