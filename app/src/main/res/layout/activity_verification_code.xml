<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/verificationCodeMain"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_welcome_gradient"
    tools:context=".VerificationCodeActivity">

    <!-- Back arrow -->
    <ImageView
        android:id="@+id/ivBack"
        android:layout_width="32dp"
        android:layout_height="32dp"
        android:layout_marginStart="16dp"
        android:layout_marginTop="16dp"
        android:src="@drawable/ic_arrow_back"
        android:contentDescription="Volver"
        android:clickable="true"
        android:focusable="true"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- Title: Código enviado -->
    <TextView
        android:id="@+id/tvCodeTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/verification_title"
        android:textColor="@color/purple_login"
        android:textSize="28sp"
        android:textStyle="normal"
        android:fontFamily="sans-serif"
        android:layout_marginTop="48dp"
        android:layout_marginStart="32dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/ivBack" />

    <!-- Code Input Row -->
    <LinearLayout
        android:id="@+id/codeInputRow"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:layout_marginTop="48dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tvCodeTitle">

        <!-- Digit 1 -->
        <EditText
            android:id="@+id/etCode1"
            android:layout_width="40dp"
            android:layout_height="48dp"
            android:background="@drawable/bg_code_input"
            android:gravity="center"
            android:inputType="number"
            android:maxLength="1"
            android:textColor="@color/purple_login"
            android:textSize="20sp"
            android:textStyle="bold"
            android:layout_marginEnd="8dp" />

        <!-- Digit 2 -->
        <EditText
            android:id="@+id/etCode2"
            android:layout_width="40dp"
            android:layout_height="48dp"
            android:background="@drawable/bg_code_input"
            android:gravity="center"
            android:inputType="number"
            android:maxLength="1"
            android:textColor="@color/purple_login"
            android:textSize="20sp"
            android:textStyle="bold"
            android:layout_marginEnd="8dp" />

        <!-- Digit 3 -->
        <EditText
            android:id="@+id/etCode3"
            android:layout_width="40dp"
            android:layout_height="48dp"
            android:background="@drawable/bg_code_input"
            android:gravity="center"
            android:inputType="number"
            android:maxLength="1"
            android:textColor="@color/purple_login"
            android:textSize="20sp"
            android:textStyle="bold" />

        <!-- Dash separator -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text=" - "
            android:textColor="#333333"
            android:textSize="24sp"
            android:textStyle="bold"
            android:layout_marginStart="8dp"
            android:layout_marginEnd="8dp" />

        <!-- Digit 4 -->
        <EditText
            android:id="@+id/etCode4"
            android:layout_width="40dp"
            android:layout_height="48dp"
            android:background="@drawable/bg_code_input"
            android:gravity="center"
            android:inputType="number"
            android:maxLength="1"
            android:textColor="@color/purple_login"
            android:textSize="20sp"
            android:textStyle="bold"
            android:layout_marginEnd="8dp" />

        <!-- Digit 5 -->
        <EditText
            android:id="@+id/etCode5"
            android:layout_width="40dp"
            android:layout_height="48dp"
            android:background="@drawable/bg_code_input"
            android:gravity="center"
            android:inputType="number"
            android:maxLength="1"
            android:textColor="@color/purple_login"
            android:textSize="20sp"
            android:textStyle="bold"
            android:layout_marginEnd="8dp" />

        <!-- Digit 6 -->
        <EditText
            android:id="@+id/etCode6"
            android:layout_width="40dp"
            android:layout_height="48dp"
            android:background="@drawable/bg_code_input"
            android:gravity="center"
            android:inputType="number"
            android:maxLength="1"
            android:textColor="@color/purple_login"
            android:textSize="20sp"
            android:textStyle="bold" />

    </LinearLayout>

    <!-- Reenviar código -->
    <TextView
        android:id="@+id/tvResendCode"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/verification_resend"
        android:textColor="@color/purple_login"
        android:textSize="14sp"
        android:layout_marginTop="32dp"
        android:layout_marginStart="32dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/codeInputRow" />

    <!-- Countdown message -->
    <TextView
        android:id="@+id/tvCountdown"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="@string/verification_countdown"
        android:textColor="#666666"
        android:textSize="13sp"
        android:layout_marginTop="4dp"
        android:layout_marginStart="32dp"
        android:layout_marginEnd="32dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tvResendCode" />

    <!-- Verificar button -->
    <androidx.appcompat.widget.AppCompatButton
        android:id="@+id/btnVerificar"
        android:layout_width="wrap_content"
        android:layout_height="48dp"
        android:text="@string/verification_btn"
        android:textColor="@color/white"
        android:textSize="16sp"
        android:textAllCaps="false"
        android:background="@drawable/bg_btn_verificar"
        app:backgroundTint="@null"
        android:backgroundTint="@null"
        android:stateListAnimator="@null"
        android:paddingStart="40dp"
        android:paddingEnd="40dp"
        android:layout_marginTop="32dp"
        android:layout_marginEnd="32dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tvCountdown" />

    <!-- Mas informacion -->
    <TextView
        android:id="@+id/tvMoreInfo"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/verification_more_info"
        android:textColor="@color/purple_login"
        android:textSize="14sp"
        android:layout_marginBottom="48dp"
        android:layout_marginEnd="32dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toBottomOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
