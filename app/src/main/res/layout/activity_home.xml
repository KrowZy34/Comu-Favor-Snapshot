<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/homeMain"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_welcome_gradient"
    tools:context=".HomeActivity">

    <!-- Welcome message -->
    <TextView
        android:id="@+id/tvWelcome"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:textColor="@color/green_accent"
        android:textSize="26sp"
        android:textStyle="italic"
        android:fontFamily="sans-serif"
        android:gravity="center"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toTopOf="@id/ivPersonIcon"
        android:layout_marginBottom="32dp"
        android:layout_marginStart="32dp"
        android:layout_marginEnd="32dp" />

    <!-- Person icon in circle -->
    <ImageView
        android:id="@+id/ivPersonIcon"
        android:layout_width="100dp"
        android:layout_height="100dp"
        android:src="@drawable/ic_person_circle"
        android:contentDescription="@string/app_name"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintVertical_bias="0.35" />

    <!-- Siguiente button -->
    <Button
        android:id="@+id/btnSiguiente"
        android:layout_width="0dp"
        android:layout_height="52dp"
        android:text="@string/btn_siguiente_arrow"
        android:textColor="@color/green_accent"
        android:textSize="16sp"
        android:textAllCaps="false"
        android:background="@drawable/btn_login_border"
        android:stateListAnimator="@null"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toTopOf="@id/tvNeedHelp"
        android:layout_marginBottom="20dp"
        android:layout_marginStart="48dp"
        android:layout_marginEnd="48dp" />

    <!-- Necesitas ayuda? -->
    <TextView
        android:id="@+id/tvNeedHelp"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/need_help"
        android:textColor="@color/white"
        android:textSize="14sp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        android:layout_marginBottom="48dp" />

</androidx.constraintlayout.widget.ConstraintLayout>
