<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:app="http://schemas.android.com/apk/res-auto" xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/paymentMain"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/dark_background"
    tools:context=".PaymentMethodsActivity">

    <!-- Header: title + Omitir -->
    <LinearLayout
        android:id="@+id/paymentHeader"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="24dp"
        android:paddingEnd="24dp"
        android:paddingTop="48dp"
        android:paddingBottom="16dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/payment_title"
            android:textColor="@color/green_accent"
            android:textSize="22sp"
            android:textStyle="bold"
            android:fontFamily="sans-serif" />

        <TextView
            android:id="@+id/tvOmitir"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/payment_skip"
            android:textColor="@color/input_hint"
            android:textSize="14sp"
            android:padding="8dp" />

    </LinearLayout>

    <ScrollView
        android:id="@+id/paymentScroll"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintTop_toBottomOf="@+id/paymentHeader"
        app:layout_constraintBottom_toTopOf="@+id/paymentBottomButtons"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:fillViewport="true"
        android:scrollbars="none">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:paddingBottom="16dp">

            <!-- ═══ TARJETAS SECTION ═══ -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_card_section"
                android:padding="16dp"
                android:layout_marginBottom="12dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/payment_cards"
                    android:textColor="@color/white"
                    android:textSize="15sp"
                    android:layout_marginBottom="12dp" />

                <!-- Agrega Tarjetas row (clickable) -->
                <LinearLayout
                    android:id="@+id/rowAddCard"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:padding="8dp">

                    <ImageView
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:src="@drawable/ic_add_card"
                        android:contentDescription="@string/payment_add_card"
                        android:layout_marginEnd="12dp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/payment_add_card"
                        android:textColor="@color/white"
                        android:textSize="15sp" />

                </LinearLayout>

                <!-- Card input form (hidden by default) -->
                <LinearLayout
                    android:id="@+id/cardInputForm"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:visibility="gone"
                    android:layout_marginTop="8dp">

                    <!-- Card number -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/payment_card_number"
                        android:textColor="@color/input_hint"
                        android:textSize="13sp"
                        android:layout_marginTop="8dp" />

                    <EditText
                        android:id="@+id/etCardNumber"
                        android:layout_width="match_parent"
                        android:layout_height="42dp"
                        android:hint="@string/payment_card_number"
                        android:textColorHint="@color/input_hint"
                        android:textColor="@color/white"
                        android:textSize="16sp"
                        android:inputType="number"
                        android:background="@android:color/transparent"
                        android:maxLength="19"
                        android:paddingStart="0dp"
                        android:paddingEnd="0dp" />

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="@color/input_hint" />

                    <!-- Expiry + CVV row -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginTop="12dp">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:layout_marginEnd="16dp">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/payment_expiry"
                                android:textColor="@color/input_hint"
                                android:textSize="13sp" />

                            <EditText
                                android:id="@+id/etExpiry"
                                android:layout_width="match_parent"
                                android:layout_height="42dp"
                                android:hint="@string/payment_expiry"
                                android:textColorHint="@color/input_hint"
                                android:textColor="@color/white"
                                android:textSize="16sp"
                                android:inputType="number"
                                android:maxLength="5"
                                android:background="@android:color/transparent"
                                android:paddingStart="0dp"
                                android:paddingEnd="0dp" />

                            <View
                                android:layout_width="match_parent"
                                android:layout_height="1dp"
                                android:background="@color/input_hint" />

                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/payment_cvv"
                                android:textColor="@color/input_hint"
                                android:textSize="13sp" />

                            <EditText
                                android:id="@+id/etCvv"
                                android:layout_width="match_parent"
                                android:layout_height="42dp"
                                android:hint="@string/payment_cvv"
                                android:textColorHint="@color/input_hint"
                                android:textColor="@color/white"
                                android:textSize="16sp"
                                android:inputType="numberPassword"
                                android:maxLength="4"
                                android:background="@android:color/transparent"
                                android:paddingStart="0dp"
                                android:paddingEnd="0dp" />

                            <View
                                android:layout_width="match_parent"
                                android:layout_height="1dp"
                                android:background="@color/input_hint" />

                        </LinearLayout>

                    </LinearLayout>

                </LinearLayout>

            </LinearLayout>

            <!-- ═══ OTROS SECTION ═══ -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_card_section"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/payment_others"
                    android:textColor="@color/white"
                    android:textSize="15sp"
                    android:layout_marginBottom="8dp" />

                <!-- Yape -->
                <LinearLayout
                    android:id="@+id/rowYape"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingTop="12dp"
                    android:paddingBottom="12dp"
                    android:paddingStart="8dp"
                    android:paddingEnd="8dp">

                    <View
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:background="@drawable/bg_yape_icon"
                        android:layout_marginEnd="12dp" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/payment_yape"
                        android:textColor="@color/white"
                        android:textSize="15sp" />

                    <RadioButton
                        android:id="@+id/rbYape"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:buttonTint="@color/green_accent" />

                </LinearLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="#333333"
                    android:layout_marginStart="56dp" />

                <!-- PayPal -->
                <LinearLayout
                    android:id="@+id/rowPaypal"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingTop="12dp"
                    android:paddingBottom="12dp"
                    android:paddingStart="8dp"
                    android:paddingEnd="8dp">

                    <View
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:background="@drawable/bg_paypal_icon"
                        android:layout_marginEnd="12dp" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/payment_paypal"
                        android:textColor="@color/white"
                        android:textSize="15sp" />

                    <RadioButton
                        android:id="@+id/rbPaypal"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:buttonTint="@color/green_accent" />

                </LinearLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="#333333"
                    android:layout_marginStart="56dp" />

                <!-- Mercado Pago -->
                <LinearLayout
                    android:id="@+id/rowMercadoPago"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingTop="12dp"
                    android:paddingBottom="12dp"
                    android:paddingStart="8dp"
                    android:paddingEnd="8dp">

                    <View
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:background="@drawable/bg_mercadopago_icon"
                        android:layout_marginEnd="12dp" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/payment_mercadopago"
                        android:textColor="@color/white"
                        android:textSize="15sp" />

                    <RadioButton
                        android:id="@+id/rbMercadoPago"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:buttonTint="@color/green_accent" />

                </LinearLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="#333333"
                    android:layout_marginStart="56dp" />

                <!-- Efectivo -->
                <LinearLayout
                    android:id="@+id/rowEfectivo"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingTop="12dp"
                    android:paddingBottom="12dp"
                    android:paddingStart="8dp"
                    android:paddingEnd="8dp">

                    <View
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:background="@drawable/bg_efectivo_icon"
                        android:layout_marginEnd="12dp" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/payment_efectivo"
                        android:textColor="@color/white"
                        android:textSize="15sp" />

                    <RadioButton
                        android:id="@+id/rbEfectivo"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:buttonTint="@color/green_accent" />

                </LinearLayout>

            </LinearLayout>

        </LinearLayout>
    </ScrollView>

    <!-- ═══ BOTTOM BUTTONS ═══ -->
    <LinearLayout
        android:id="@+id/paymentBottomButtons"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:paddingTop="12dp"
        android:paddingBottom="32dp"
        android:gravity="center"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <Button
            android:id="@+id/btnAddCard"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:text="@string/payment_btn_add_card"
            android:textColor="#555555"
            android:textSize="14sp"
            android:textAllCaps="false"
            android:background="@drawable/btn_disabled_border"
            android:stateListAnimator="@null"
            android:enabled="false"
            android:layout_marginEnd="8dp" />

        <Button
            android:id="@+id/btnSiguiente"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:text="@string/payment_btn_next"
            android:textColor="#555555"
            android:textSize="14sp"
            android:textAllCaps="false"
            android:background="@drawable/btn_disabled_border"
            android:stateListAnimator="@null"
            android:enabled="false"
            android:layout_marginStart="8dp" />

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
