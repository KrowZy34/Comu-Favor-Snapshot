<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/recPostMain"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/black"
    tools:context=".RecPostActivity">

    <!-- Header -->
    <LinearLayout
        android:id="@+id/recPostHeader"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingTop="48dp"
        android:paddingBottom="16dp"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        app:layout_constraintTop_toTopOf="parent">

        <ImageView
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:src="@drawable/ic_menu_green"
            android:contentDescription="Menu" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:layout_marginStart="16dp"
            android:background="@drawable/bg_search_bar"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="16dp"
            android:paddingEnd="16dp">

            <EditText
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:background="@android:color/transparent"
                android:hint="@string/search_hint"
                android:textColorHint="@color/card_border"
                android:textColor="@color/white"
                android:textSize="16sp"
                android:maxLines="1"
                android:singleLine="true" />

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_search"
                android:contentDescription="Search" />

        </LinearLayout>
    </LinearLayout>

    <ScrollView
        android:id="@+id/recPostScroll"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintTop_toBottomOf="@id/recPostHeader"
        app:layout_constraintBottom_toTopOf="@id/bottomNavDivider"
        app:layout_constraintStart_toStartOf="parent"
        android:fillViewport="true"
        android:scrollbars="none">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="24dp"
            android:paddingEnd="24dp"
            android:paddingBottom="16dp">

            <!-- Toggle Reclutando / Postulando -->
            <LinearLayout
                android:id="@+id/llToggle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:background="@drawable/bg_rec_post_toggle"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:paddingTop="6dp"
                android:paddingBottom="6dp"
                android:layout_marginBottom="24dp">

                <TextView
                    android:id="@+id/tvReclutando"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/rec_post_reclutando"
                    android:textColor="@color/rec_cyan"
                    android:textStyle="bold|italic"
                    android:textSize="14sp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/rec_post_divider"
                    android:textColor="@color/white"
                    android:textStyle="bold|italic"
                    android:textSize="14sp" />

                <TextView
                    android:id="@+id/tvPostulando"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/rec_post_postulando"
                    android:textColor="@color/white"
                    android:textStyle="italic"
                    android:textSize="14sp" />
            </LinearLayout>

            <!-- Agregar trabajo Button (Only visible in Reclutando) -->
            <Button
                android:id="@+id/btnAddJob"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:text="@string/rec_post_add_job"
                android:textColor="#80FFFFFF"
                android:textSize="15sp"
                android:textAllCaps="false"
                android:background="@drawable/bg_btn_add_job"
                android:stateListAnimator="@null"
                android:layout_marginBottom="24dp" />

            <!-- "Hoy" section -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/rec_post_hoy"
                android:textColor="@color/white"
                android:textSize="16sp"
                android:layout_marginBottom="16dp" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvJobsHoy"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:nestedScrollingEnabled="false"
                android:layout_marginBottom="16dp" />

            <!-- "Semana pasada" section (Only visible in Reclutando based on screenshot, but let's keep it togglable if needed) -->
            <TextView
                android:id="@+id/tvLastWeek"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/rec_post_last_week"
                android:textColor="@color/white"
                android:textSize="16sp"
                android:layout_marginBottom="16dp" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvJobsPastWeek"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:nestedScrollingEnabled="false" />

        </LinearLayout>
    </ScrollView>

    <!-- Bottom Navigation -->
    <View
        android:id="@+id/bottomNavDivider"
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/card_border"
        app:layout_constraintBottom_toTopOf="@id/bottomNavMain" />

    <LinearLayout
        android:id="@+id/bottomNavMain"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="@color/black"
        android:paddingTop="8dp"
        android:paddingBottom="8dp"
        android:weightSum="5"
        app:layout_constraintBottom_toBottomOf="parent">

        <!-- Rec & Post (Active in this view) -->
        <LinearLayout
            android:id="@+id/navRecPost"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">

            <!-- Needs a green tint. We can use tint or custom vector -->
            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_briefcase"
                app:tint="@color/green_accent"
                android:layout_marginBottom="4dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/nav_rec_post"
                android:textColor="@color/green_accent"
                android:textSize="10sp"
                android:textStyle="bold"
                android:textAlignment="center" />
        </LinearLayout>

        <!-- Mensajes -->
        <LinearLayout
            android:id="@+id/navMensajes"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_chat"
                android:layout_marginBottom="4dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/nav_mensajes"
                android:textColor="@color/white"
                android:textSize="10sp"
                android:textStyle="bold"
                android:textAlignment="center" />
        </LinearLayout>

        <!-- Inicio (Inactive) -->
        <LinearLayout
            android:id="@+id/navInicio"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">

            <ImageView
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:src="@drawable/ic_home_filled"
                app:tint="@color/white"
                android:layout_marginBottom="2dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/nav_inicio"
                android:textColor="@color/white"
                android:textSize="10sp"
                android:textStyle="bold"
                android:textAlignment="center" />
        </LinearLayout>

        <!-- Guardados -->
        <LinearLayout
            android:id="@+id/navGuardados"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_bookmark"
                android:layout_marginBottom="4dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/nav_guardados"
                android:textColor="@color/white"
                android:textSize="10sp"
                android:textStyle="bold"
                android:textAlignment="center" />
        </LinearLayout>

        <!-- Perfil -->
        <LinearLayout
            android:id="@+id/navPerfil"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_profile_outline"
                android:layout_marginBottom="4dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/nav_perfil"
                android:textColor="@color/white"
                android:textSize="10sp"
                android:textStyle="bold"
                android:textAlignment="center" />
        </LinearLayout>

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
