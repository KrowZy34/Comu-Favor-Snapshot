    <string name="verification_info_title">Información</string>
    <string name="verification_info_subtitle">por que pedimos un código de verificación?</string>
    <string name="verification_info_reason_1_title">1. Verificación del número telefónico</string>
    <string name="verification_info_reason_1_desc">Permite confirmar que el usuario tiene acceso real al número de teléfono registrado.</string>
    <string name="verification_info_reason_2_title">2. Prevención de cuentas falsas</string>
    <string name="verification_info_reason_2_desc">Ayuda a reducir la creación de cuentas falsas o automatizadas (bots).</string>
    <string name="verification_info_reason_3_title">3. Recuperación de la cuenta</string>
    <string name="verification_info_reason_3_desc">Facilita que el usuario pueda recuperar el acceso en caso de olvidar su contraseña.</string>
    <string name="verification_info_reason_4_title">4. Mayor seguridad</string>
    <string name="verification_info_reason_4_desc">Funciona como un método adicional de verificación para proteger la cuenta del usuario.</string>
    <string name="verification_info_reason_5_title">5. Comunicación confiable</string>
    <string name="verification_info_reason_5_desc">Garantiza que la aplicación tenga un número válido para enviar notificaciones o información importante.</string>

